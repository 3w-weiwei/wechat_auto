{
  "name": "wechat-auto",
  "version": "4.0.0",
  "description": "智推助手 - 微信智能群发工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.vv339.wechat-auto",
    "productName": "智推助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "python-manager.js",
      "dist/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1"
  }
}
